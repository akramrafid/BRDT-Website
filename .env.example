# ============================================
# BRDT Charity Website - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=BRDT Charity
VITE_ENVIRONMENT=development

# ============================================
# Backend Configuration
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=brdt_charity

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# ============================================
# Email Configuration
# ============================================
# Option A: Gmail (for testing)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Option B: SendGrid (for production)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Email Settings
BRDT_EMAIL=noreply@brdtrust.org
BRDT_DISPLAY_NAME=BRDT - Belghar Rural Development Trust
EMAIL_FROM_NAME=BRDT Charity

# ============================================
# Organization Details
# ============================================
ORG_NAME=Belghar Rural Development Trust
ORG_PHONE=+44 7540 253384
ORG_WEBSITE=https://www.brdtrust.org
ORG_ADDRESS=Belghar, Bangladesh
ORG_EMAIL=contact@brdtrust.org

# ============================================
# Stripe Configuration
# ============================================
# Test Keys (prefix: pk_test_ and sk_test_)
# Production Keys (prefix: pk_live_ and sk_live_)
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Currency Settings
STRIPE_CURRENCY=gbp
DEFAULT_CURRENCY=GBP

# ============================================
# Payment Configuration
# ============================================
MIN_DONATION=1.00
MAX_DONATION=10000.00

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ============================================
# Security
# ============================================
CORS_ORIGIN=http://localhost:8000,http://localhost:3000,http://localhost:5000
SESSION_SECRET=your_session_secret_here

# ============================================
# File Upload
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
INVOICE_DIR=./uploads/invoices

# ============================================
# Analytics (Optional)
# ============================================
# GOOGLE_ANALYTICS_ID=UA-xxxxx-xx
# SENTRY_DSN=

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================
# 1. Never commit .env to Git
# 2. Change JWT_SECRET in production to a strong random value
# 3. Use production Stripe keys (sk_live_, pk_live_) for live donations
# 4. For production emails, use SendGrid instead of Gmail
# 5. Keep all secret keys confidential
# 6. Rotate keys periodically
# 7. Use HTTPS in production (NODE_ENV=production)
# 8. Update CORS_ORIGIN to your production domain
